# Activist Tracker — Environment Config
# Copy this to .env and fill in your values

# ── EMAIL ALERTS ──────────────────────────────────────────────────
# Gmail works easiest. You need a Gmail App Password (not your regular password).
# To get one: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
ALERT_TO=recipient@email.com
